# =============================================================================
#  Ferment Station — fichier d'environnement (exemple)
# =============================================================================
#  Copie ce fichier vers `.env` à la racine du projet, puis remplis les valeurs.
#
#      cp ops/env.sample .env
#
#  ⚠️  Le fichier `.env` ne doit JAMAIS être committé (il est dans .gitignore).
#  ⚠️  Ne mets JAMAIS ici de vraies clés/identifiants de PRODUCTION.
#
#  Légende :
#    [LOCAL]  → à remplir pour développer en local
#    [VIDE]   → laisser vide en local (réservé prod) ; la fonctionnalité
#               associée sera simplement désactivée sur ta machine
#    [OPS]    → exploitation/prod uniquement, inutile pour le dev
# =============================================================================


# ─────────────────────────────────────────────────────────────────────────────
#  A. BASE DE DONNÉES  [LOCAL — obligatoire]
# ─────────────────────────────────────────────────────────────────────────────
#  Pointe vers TA Postgres locale (jamais la prod). Le code accepte soit les
#  variables séparées ci-dessous, soit une URL complète via DATABASE_URL.
#
#  Mise en place rapide d'une base locale :
#    createdb ferment_local
#  (ou via Postgres.app / Docker — au choix)

DB_HOST=localhost
DB_PORT=5432
DB_DATABASE=ferment_local
DB_USERNAME=postgres
DB_PASSWORD=
# `require` en prod (SSL). En local : `disable` ou `prefer`.
DB_SSLMODE=disable

# Alternative : une seule URL au lieu des 5 variables ci-dessus.
# Si renseignée, elle a la priorité.
# DATABASE_URL=postgresql://postgres@localhost:5432/ferment_local


# ─────────────────────────────────────────────────────────────────────────────
#  B. APPLICATION / SÉCURITÉ  [LOCAL — obligatoire]
# ─────────────────────────────────────────────────────────────────────────────
# Environnement : `development` en local, `production` sur le serveur.
ENV=development

# Clé secrète des sessions NiceGUI — mets n'importe quelle chaîne longue
# (≥ 32 caractères) générée au hasard. Ex : `openssl rand -hex 32`
NICEGUI_SECRET=change-moi-une-chaine-aleatoire-de-32-caracteres-minimum

# URL publique de l'app (sert à fabriquer les liens reset/invitation).
# En local, laisse localhost.
BASE_URL=http://localhost:8502

# Port d'écoute (optionnel, défaut 8502).
# NICEGUI_PORT=8502

# Organisations autorisées à se créer (whitelist). Pour le dev, garde un
# tenant de test. Sépare par des virgules si plusieurs.
ALLOWED_TENANTS=Tenant Test

# Niveau de log (optionnel : DEBUG, INFO, WARNING).
# LOG_LEVEL=INFO

# Durées de validité des liens (optionnel, valeurs par défaut raisonnables).
# RESET_TTL_MINUTES=60
# INVITE_TTL_MINUTES=10080


# ─────────────────────────────────────────────────────────────────────────────
#  C. EMAIL / BREVO  [VIDE en local]
# ─────────────────────────────────────────────────────────────────────────────
#  Laisse vide en local : aucun e-mail ne partira (invitations, reset,
#  notifications ramasse), mais le reste de l'app et les tests fonctionnent.
#  Ne renseigne ces valeurs QUE sur le serveur, avec la vraie clé Brevo.

BREVO_API_KEY=
EMAIL_SENDER=
EMAIL_SENDER_NAME=
EMAIL_ALWAYS_CC=
# Variables historiques équivalentes (selon le module) :
SENDER_EMAIL=
SENDER_NAME=


# ─────────────────────────────────────────────────────────────────────────────
#  D. INTÉGRATION EASYBEER  [VIDE en local]
# ─────────────────────────────────────────────────────────────────────────────
#  API de l'ERP brasserie. Laisse vide en local : les fonctions qui lisent
#  EasyBeer (planning, conditionnement, poids produits…) seront inactives,
#  mais ça ne bloque ni l'app ni les tests. Réservé prod.

EASYBEER_API_USER=
EASYBEER_API_PASS=
EASYBEER_ID_BRASSERIE=
EB_SOFRIPA_CLIENT_ID=
EB_DEFAULT_WAREHOUSE_ID=
EB_DEFAULT_SORTIE_TYPE_ID=
EB_OUTBOX_BIND_LOADINGS=
EB_OUTBOX_BIND_PRODUCTION_SHEETS=


# ─────────────────────────────────────────────────────────────────────────────
#  E. OPTIONNEL  [VIDE en local]
# ─────────────────────────────────────────────────────────────────────────────
# Suivi des erreurs (Sentry) — vide en local, renseigné en prod.
SENTRY_DSN=

# Génération de commandes fournisseurs via Claude — optionnel.
# Si vide, le bouton "Préparer la commande" est masqué.
ANTHROPIC_API_KEY=


# ─────────────────────────────────────────────────────────────────────────────
#  F. EXPLOITATION / PROD UNIQUEMENT  [OPS — ne pas remplir pour le dev]
# ─────────────────────────────────────────────────────────────────────────────
#  Sauvegardes, agent d'impression d'étiquettes, supervision VPS. Inutile en
#  développement. Documenté ici pour référence.
#
# BACKUP_DIR=
# S3_BACKUP_PREFIX=
# RETENTION_DAYS=
# ALERT_EMAIL=
# PRINT_AGENT_TOKEN=
# PRINT_AGENT_TENANT_ID=
# PRINTER_NAME=
# VPS_URL=
