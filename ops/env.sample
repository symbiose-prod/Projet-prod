
---

> 📍Chemin : `Projet-prod/ops/env.sample`

```bash
# === Configuration de l'application Streamlit Ferment Station ===

# URL publique de l'app (sans / final)
BASE_URL=https://fermentstation-15i6c.kinsta.app

# --- Base de données Postgres ---
DB_HOST=your-db-host
DB_PORT=5432
DB_DATABASE=your-db-name
DB_USERNAME=your-db-user
DB_PASSWORD=your-db-password
DB_SSLMODE=require

# --- Email / Brevo ---
BREVO_API_KEY=your-brevo-key
EMAIL_SENDER=station.ferment@gmail.com
EMAIL_SENDER_NAME=Ferment Station
EMAIL_REPLY_TO=station.ferment@gmail.com
EMAIL_RECIPIENTS=logistique@transporteur.com,expedition@fermentstation.fr
EMAIL_PROVIDER=brevo

# --- Reset password ---
RESET_TTL_MINUTES=60

# --- EasyBeer API ---
EASYBEER_API_USER=your-easybeer-user
EASYBEER_API_PASS=your-easybeer-pass
EASYBEER_ID_BRASSERIE=2013

# --- Claude AI (commandes fournisseurs) ---
# Optionnel : si absent, le bouton "Préparer la commande" est masqué
ANTHROPIC_API_KEY=

# --- Sécurité ---
NICEGUI_SECRET=your-secret-key-min-32-chars
ALLOWED_TENANTS=Symbiose Kéfir

# --- GitHub / déploiement ---
ENV=production
GH_REPO=symbiose-prod/Projet-prod
GH_BRANCH=main
GH_TOKEN=ghp_xxxxxxxxxxxxxxxxxxx
GH_PATH_MEMOIRE=
