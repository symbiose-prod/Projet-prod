# Configuration de l'agent d'impression Brother
# Copie ce fichier en .env et remplis les valeurs.

# URL du VPS Ferment Station
VPS_URL=https://prod.symbiose-kefir.fr

# Token bearer partagé avec le VPS (généré une fois avec : openssl rand -hex 32)
# DOIT être identique à PRINT_AGENT_TOKEN dans le .env du VPS.
AGENT_TOKEN=

# Nom EXACT de l'imprimante dans Windows (Imprimantes & scanners).
# Vide = utilise l'imprimante par défaut Windows.
# Exemple : Brother QL-1110NWBc
PRINTER_NAME=

# Timeout HTTP du long-poll (>= 25s côté serveur, < 60s côté Caddy)
POLL_TIMEOUT_S=30

# Délai entre tentatives en cas d'erreur réseau
RETRY_BACKOFF_S=5
